# /etc/cron.d/a-stock-screen  (Asia/Shanghai)
# A股交易日 15:35-15:50 自动跑全流程;周末与节假日不跑
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
PROJECT=/Users/maerun/Documents/Projects/make-money
PYTHON=$PROJECT/.venv/bin/python

35 15 * * 1-5  cd $PROJECT && $PYTHON -m py.screener --no-html > data/screen/cron.log 2>&1
40 15 * * 1-5  cd $PROJECT && $PYTHON -m py.screener --render-only >> data/screen/cron.log 2>&1
45 15 * * 1-5  cd $PROJECT && $PYTHON -m py.brief --from-screener today --top-n 10 >> data/screen/cron.log 2>&1